    <!-- AOS JS & Init -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            once: true,
            duration: 800,
            easing: 'ease-out-quart'
        });

        // Theme Toggle Logic
        // Theme Toggle Logic
        document.addEventListener('DOMContentLoaded', () => {
            const html = document.documentElement;

            // Sync Icons on Load
            const currentTheme = html.getAttribute('data-bs-theme');
            updateIcons(currentTheme);

            // Bind click events to ALL toggle buttons (desktop & mobile)
            const toggleBtns = document.querySelectorAll('.theme-toggle-btn');
            toggleBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const currentTheme = html.getAttribute('data-bs-theme');
                    const newTheme = currentTheme === 'light' ? 'dark' : 'light';
                    setTheme(newTheme);
                });
            });

            function setTheme(theme) {
                html.setAttribute('data-bs-theme', theme);
                localStorage.setItem('theme', theme);
                updateIcons(theme);
            }

            function updateIcons(theme) {
                const icons = document.querySelectorAll('.theme-icon-active');
                icons.forEach(icon => {
                    if (theme === 'dark') {
                        icon.classList.remove('bi-moon-stars-fill');
                        icon.classList.add('bi-sun-fill');
                    } else {
                        icon.classList.remove('bi-sun-fill');
                        icon.classList.add('bi-moon-stars-fill');
                    }
                });
            }
        });

        // Landing Page Billing Toggle
        const lpToggle = document.getElementById('lpBillingToggle');
        if (lpToggle) {
            const lpLabelMonthly = document.getElementById('lp-label-monthly');
            const lpLabelYearly = document.getElementById('lp-label-yearly');

            lpToggle.addEventListener('change', function() {
                const isYearly = this.checked;
                lpLabelMonthly.classList.toggle('text-muted', isYearly);
                lpLabelMonthly.classList.toggle('fw-bold', !isYearly);
                lpLabelYearly.classList.toggle('text-muted', !isYearly);
                lpLabelYearly.classList.toggle('fw-bold', isYearly);

                document.querySelectorAll('.lp-plan-price').forEach(el => {
                    const price = isYearly ? el.dataset.yearly : el.dataset.monthly;
                    el.textContent = '₹' + price;
                });

                document.querySelectorAll('.lp-plan-suffix').forEach(el => {
                    el.textContent = isYearly ? '/yr' : '/mo';
                });
            });
        }
    </script>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>