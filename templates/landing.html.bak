{% load static i18n %}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <link rel="icon" type="image/svg+xml" href="{% static 'icon.svg' %}">
    <link rel="icon" type="image/png" href="{% static 'img/pwa-icon-512.png' %}">
    
    <script>
        // Immediate Theme Detection (Prevents Flickering)
        (function() {
            const getStoredTheme = () => localStorage.getItem('theme');
            const getPreferredTheme = () => {
                const storedTheme = getStoredTheme();
                if (storedTheme) return storedTheme;
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            };
            const theme = getPreferredTheme();
            document.documentElement.setAttribute('data-bs-theme', theme);
        })();

        // Robust Mobile App / Capacitor Detection
        (function() {
            const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
            const isCapacitor = window.Capacitor || (window.webkit && window.webkit.messageHandlers && window.webkit.messageHandlers.bridge);
            const isStandalone = window.navigator.standalone || window.matchMedia('(display-mode: standalone)').matches;
            
            if (isMobile && (isCapacitor || isStandalone)) {
                document.documentElement.classList.add('is-mobile-app');
            }
        })();
    </script>
    <title>TrackMyRupee - Know Exactly Where Every Rupee Goes</title>

    <!-- SEO Meta Tags -->
    <meta name="description"
        content="TrackMyRupee: The best finance tracker for India. Monitor expenses, manage budgets, and gain financial clarity with our precision dashboard. Start tracking today!">
    <meta name="keywords"
        content="best finance tracker, expense tracker india, budget app, personal finance manager, rupee tracker, money management software, spending tracker, track my rupee">
    <meta name="author" content="Omkar Pathak">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://trackmyrupee.com/">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://trackmyrupee.com/">
    <meta property="og:title" content="TrackMyRupee | Best Finance Tracker">
    <meta property="og:description"
        content="Stop guessing where your money goes. Use TrackMyRupee, the best finance tracker to monitor expenses and grow savings.">
    <meta property="og:image" content="https://trackmyrupee.com/static/img/og-preview.png">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="https://trackmyrupee.com/">
    <meta name="twitter:title" content="TrackMyRupee | Best Finance Tracker">
    <meta name="twitter:description"
        content="Stop guessing where your money goes. Use TrackMyRupee, the best finance tracker to monitor expenses and grow savings.">
    <meta name="twitter:image" content="https://trackmyrupee.com/static/img/og-preview.png">

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "TrackMyRupee",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "INR"
      },
      "description": "TrackMyRupee is the best finance tracker for managing personal expenses, budgeting, and gaining financial clarity.",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "ratingCount": "1250"
      },
      "author": {
          "@type": "Person",
          "name": "Omkar Pathak"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "TrackMyRupee",
      "url": "https://trackmyrupee.com",
      "logo": "https://trackmyrupee.com/static/img/icon.png",
      "sameAs": [
        "https://twitter.com/trackmyrupee",
        "https://github.com/omkarpathak/trackmyrupee"
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "What is the best free finance tracker for India?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "TrackMyRupee is the best free finance tracker designed for the Indian market, offering currency support (₹), recurring payment reminders, and expense analysis."
        }
      }, {
        "@type": "Question",
        "name": "Does TrackMyRupee support recurring payments?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, TrackMyRupee features a robust Smart Notification system that sends alerts via Email, Web Push, and In-App notifications for all your recurring subscriptions and bills."
        }
      }, {
        "@type": "Question",
        "name": "Is TrackMyRupee safe to use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, TrackMyRupee prioritizes user privacy. We do not sell your data. We use secure authentication and follow best practices for data protection."
        }
      }, {
        "@type": "Question",
        "name": "Can I use TrackMyRupee on mobile?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. TrackMyRupee is a Progressive Web App (PWA), meaning you can install it on your Android or iOS device and use it just like a native app."
        }
      }]
    }
    </script>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" media="print" onload="this.media='all'">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Outfit:wght@300;400;500;700&display=swap">
    <link
        href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Outfit:wght@300;400;500;700&display=swap"
        rel="stylesheet">
    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        :root {
            /* Light Mode (Default) */
            --primary-gradient: linear-gradient(135deg, #00f260 0%, #0575e6 100%);
            --surface-color: #ffffff;
            --bg-color: #f8f9fa;
            --text-main: #212529;
            --text-muted: #6c757d;
            --accent-glow: rgba(5, 117, 230, 0.15);
            --navbar-bg: rgba(255, 255, 255, 0.85);
            --border-color: rgba(0, 0, 0, 0.05);
            --input-bg: #ffffff;
        }

        [data-bs-theme="dark"] {
            /* Dark Mode Overrides */
            --surface-color: #1a1d21;
            --bg-color: #0b0d0e;
            --text-main: #ffffff;
            --text-muted: #a1a1aa;
            --accent-glow: rgba(5, 117, 230, 0.4);
            --navbar-bg: rgba(11, 13, 14, 0.8);
            --border-color: rgba(255, 255, 255, 0.05);
            --input-bg: rgba(255, 255, 255, 0.05);
        }

        html,
        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            overflow-x: hidden;
            line-height: 1.6;
            transition: background-color 0.3s ease, color 0.3s ease;
            width: 100%;
        }

        h1,
        h2,
        h3,
        h4,
        .brand-font {
            font-family: 'Clash Display', sans-serif;
            letter-spacing: -0.02em;
        }

        .img-dark,
        .img-light {
            display: none !important;
        }

        /* Default visibility when theme is not yet detected */
        html:not([data-bs-theme]) .img-light,
        [data-bs-theme="light"] .img-light {
            display: block !important;
        }

        [data-bs-theme="dark"] .img-dark {
            display: block !important;
        }

        .navbar {
            backdrop-filter: blur(20px);
            background-color: var(--navbar-bg);
            border-bottom: 1px solid var(--border-color);
            transition: all 0.3s ease;
        }

        .hero-section {
            padding: 80px 0 100px 0;
            background: radial-gradient(circle at 50% -20%, var(--accent-glow) 0%, rgba(0, 0, 0, 0) 50%);
            min-height: 90vh;
            display: flex;
            align-items: center;
        }

        .cta-button {
            background: var(--primary-gradient);
            border: none;
            color: white;
            padding: 14px 36px;
            border-radius: 50px;
            font-weight: 700;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 20px rgba(5, 117, 230, 0.2);
        }

        .cta-button:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 30px rgba(5, 117, 230, 0.4);
            color: white;
        }

        .feature-showcase {
            padding: 100px 0;
        }

        .mockup-container {
            position: relative;
            /* Box styles removed as per user request */
            max-width: 90%;
            margin: 0 auto;
        }

        .mockup-container img {
            width: 100%;
            height: auto;
            display: block;
        }

        .btn-theme-adaptive {
            color: var(--text-main);
            border: 1px solid var(--text-main);
            transition: all 0.3s ease;
        }

        .btn-theme-adaptive:hover {
            background-color: var(--text-main);
            color: var(--bg-color);
        }

        .feature-icon-box {
            width: 60px;
            height: 60px;
            background: var(--primary-gradient);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            margin-bottom: 1.5rem;
            box-shadow: 0 10px 20px rgba(0, 242, 96, 0.2);
        }

        .text-gradient {
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .stats-badge {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50px;
            padding: 6px 16px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            font-size: 0.9rem;
            font-weight: 500;
        }

        .floating-ui {
            animation: float 6s ease-in-out infinite;
        }

        @keyframes float {
            0% {
                transform: translateY(0px) rotate(0deg);
            }

            50% {
                transform: translateY(-20px) rotate(1deg);
            }

            100% {
                transform: translateY(0px) rotate(0deg);
            }
        }

        .step-card {
            background: var(--surface-color);
            padding: 2.5rem;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            height: 100%;
            transition: all 0.3s ease;
        }

        .step-number {
            position: absolute;
            top: 2.5rem;   /* Align with card padding */
            right: 2.5rem; /* Align with card right padding */
            font-size: 3rem;
            font-weight: 800;
            color: rgba(128, 128, 128, 0.15); /* Match the subtle grey from the image */
            line-height: 1;
            /* Flex center vertically against a 48px/3rem icon block */
            height: 3rem;
            display: flex;
            align-items: center;
        }

        .process-section {
            background: rgba(255, 255, 255, 0.02);
            padding: 120px 0;
            position: relative;
        }

        .process-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        }

        .final-cta {
            background: radial-gradient(circle at center, rgba(0, 242, 96, 0.1) 0%, transparent 70%);
            padding: 140px 0;
        }

        .scroll-indicator {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            animation: bounce 2s infinite;
            opacity: 0.5;
        }

        @keyframes bounce {

            0%,
            20%,
            50%,
            80%,
            100% {
                transform: translate(-50%, 0);
            }

            40% {
                transform: translate(-50%, -10px);
            }

            60% {
                transform: translate(-50%, -5px);
            }
        }

        /* PWA / Mobile Notch Safe Area Fixes */
        .is-mobile-app .navbar {
            padding-top: env(safe-area-inset-top, 0px) !important;
        }

        .is-mobile-app body {
            padding-bottom: env(safe-area-inset-bottom, 0px) !important;
        }

        .is-mobile-app .hero-section {
            padding-top: calc(80px + env(safe-area-inset-top, 0px)) !important;
        }

        /* Outcome-Based & Story Sections */
        .outcome-icon-box {
            width: 80px;
            height: 80px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 2rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }

        .pulse-small {
            animation: pulse-small 2s infinite;
        }

        @keyframes pulse-small {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
        }

        .story-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            background: var(--surface-color);
        }

        .story-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1) !important;
        }

        .progress {
            background-color: rgba(128, 128, 128, 0.1);
            border-radius: 10px;
        }

        .progress-bar {
            border-radius: 10px;
        }

        .outcome-icon-box i {
            font-size: 2.5rem;
        }

        /* Before vs After Section */
        .comparison-card {
            border-radius: 24px;
            overflow: hidden;
            transition: transform 0.3s ease;
            height: 100%;
        }

        .before-card {
            border: 1px solid rgba(220, 53, 69, 0.2);
            background: rgba(220, 53, 69, 0.02);
        }

        .after-card {
            border: 2px solid #0575e6;
            background: var(--surface-color);
            box-shadow: 0 20px 40px rgba(5, 117, 230, 0.1);
        }

        .comparison-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .comparison-list li {
            padding: 12px 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* --- New Aesthetic Backgrounds --- */
        .hero-section {
            background: radial-gradient(circle at 10% 20%, rgba(5, 117, 230, 0.05) 0%, transparent 40%),
                        radial-gradient(circle at 90% 80%, rgba(0, 242, 96, 0.05) 0%, transparent 40%);
            border-bottom: 1px solid rgba(var(--bs-primary-rgb), 0.05);
        }

        .privacy-gradient-bg {
            background: linear-gradient(to bottom, var(--bs-tertiary-bg), var(--bs-body-bg)) !important;
            border-top: 1px solid rgba(var(--bs-primary-rgb), 0.05);
            border-bottom: 1px solid rgba(var(--bs-primary-rgb), 0.05);
        }

        .grid-pattern-bg {
            background-color: var(--bs-body-bg);
            background-image: radial-gradient(rgba(var(--bs-primary-rgb), 0.08) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        .blue-tint-bg {
            background-color: rgba(5, 117, 230, 0.02) !important;
            border-top: 1px solid rgba(var(--bs-primary-rgb), 0.05);
            border-bottom: 1px solid rgba(var(--bs-primary-rgb), 0.05);
        }

        .white-section-bg {
            background-color: var(--bs-body-bg);
        }

        .final-cta-bg {
            background: radial-gradient(circle at 50% 100%, rgba(5, 117, 230, 0.08) 0%, var(--bs-body-bg) 100%);
            border-top: 1px solid rgba(var(--bs-primary-rgb), 0.1);
            position: relative;
            overflow: hidden;
        }
        .final-cta-bg .text-gradient {
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <!-- Navbar -->
    <!-- Navbar -->
    {% include "components/navbar.html" with is_landing=True %}

    <!-- Hero Section -->
    <section class="hero-section text-center text-lg-start">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6" data-aos="fade-right" data-aos-duration="1000">
                    <div class="stats-badge">
                        <i class="bi bi-stars text-warning"></i>
                        <span>{% trans "Join 500+ Finance Enthusiasts" %}</span>
                    </div>
                    <h1 class="display-3 fw-bold mb-4">
                        {% trans "Stop wondering where your" %}<br>
                        <span class="text-gradient">{% trans "salary disappeared." %}</span>
                    </h1>
                    <p class="lead text-muted mb-5 pe-lg-5">
                        {% blocktrans %}TrackMyRupee turns your transactions into a clear financial story — showing where your money went, what you're saving, and what your future finances look like.{% endblocktrans %}
                    </p>
                    <div class="social-proof-bar mb-5 d-flex flex-wrap gap-4 justify-content-center justify-content-lg-start align-items-center opacity-75">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-people-fill text-primary"></i>
                            <span class="small fw-bold">{% trans "Trusted by 500+ users" %}</span>
                        </div>
                        <div class="vr d-none d-sm-block"></div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-currency-rupee text-success"></i>
                            <span class="small fw-bold">{% trans "₹1Cr+ tracked" %}</span>
                        </div>
                        <div class="vr d-none d-sm-block"></div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-shield-check text-info"></i>
                            <span class="small fw-bold">{% trans "100% Privacy-First" %}</span>
                        </div>
                    </div>
                    <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
                        <a href="{% url 'account_signup' %}" class="cta-button text-decoration-none">{% trans "See My Financial Story" %} →</a>
                        <a href="{% url 'demo_login' %}"
                            class="btn btn-theme-adaptive rounded-pill px-4 py-3 fw-bold d-inline-flex align-items-center justify-content-center">
                            <i class="bi bi-rocket-takeoff me-2"></i> {% trans "Try Demo" %}
                        </a>
                    </div>
                </div>
                <div class="col-lg-6 mt-5 mt-lg-0" data-aos="zoom-in" data-aos-duration="1200">
                    <div class="mockup-container" data-aos="fade-left">
                        <img src="{% static 'img/hero_dashboard.svg' %}" alt="Analytics Dashboard" class="img-dark" fetchpriority="high" loading="eager" decoding="async">
                        <img src="{% static 'img/hero_dashboard_light.svg' %}" alt="Analytics Dashboard" class="img-light" fetchpriority="high" loading="eager" decoding="async">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- About the Maker (Moved up for trust) -->
    <section class="py-5 privacy-gradient-bg">
        <div class="container py-4">
            <div class="row justify-content-center align-items-center">
                <div class="col-lg-8 text-center" data-aos="fade-up">
                    <div class="mb-4 text-center">
                        <img src="https://github.com/OmkarPathak.png" alt="Omkar Pathak"
                            class="rounded-circle mb-3 border border-3 border-primary border-opacity-25" width="60"
                            height="60" loading="lazy" decoding="async">
                    </div>
                    <div class="d-flex flex-column align-items-center mb-4">
                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success px-3 py-2 mb-2 fw-bold">
                            <i class="bi bi-shield-check me-1"></i> {% trans "Built by an Indie Developer" %}
                        </span>
                        <div class="small text-muted fw-medium">
                            <i class="bi bi-graph-up me-1"></i> {% trans "Used by professionals tracking ₹10L+ yearly spending" %}
                        </div>
                    </div>
                    <h2 class="display-5 fw-bold mb-4">{% trans "Built by an Indie Developer" %}</h2>
                    <p class="lead text-muted mb-4">
                        {% trans "Most finance apps make money by selling your data. TrackMyRupee is different." %}
                    </p>
                    <div class="row g-4 mb-5 text-start justify-content-center">
                        <div class="col-md-4">
                            <div class="p-3 bg-body rounded-4 shadow-sm border-start border-4 border-danger h-100">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                    <span class="fw-bold">{% trans "No bank connections" %}</span>
                                </div>
                                <p class="small text-muted mb-0">{% trans "Your login credentials stay with you." %}</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-body rounded-4 shadow-sm border-start border-4 border-danger h-100">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                    <span class="fw-bold">{% trans "No SMS scraping" %}</span>
                                </div>
                                <p class="small text-muted mb-0">{% trans "We don't read your private messages." %}</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-body rounded-4 shadow-sm border-start border-4 border-danger h-100">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                    <span class="fw-bold">{% trans "No selling your data" %}</span>
                                </div>
                                <p class="small text-muted mb-0">{% trans "Your financial behavior is not for sale." %}</p>
                            </div>
                        </div>
                    </div>

                    <p class="lead text-muted mb-0">
                        {% blocktrans %}Just a simple dashboard to understand your money. Privacy is not a feature; it's our foundation.{% endblocktrans %}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Relatable Story Section (The Problem) -->
    <section class="py-5 grid-pattern-bg position-relative overflow-hidden">
        <div class="container py-5">
            <div class="row align-items-center g-5">
                <div class="col-lg-6" data-aos="fade-up">
                    <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger px-3 py-2 mb-3 fw-bold">
                        <i class="bi bi-question-circle me-1"></i> {% trans "The Disappearing Salary Mystery" %}
                    </span>
                    <h2 class="display-4 fw-bold mb-4">{% trans "End of the month." %}<br><span class="text-danger">{% trans "Salary is gone." %}</span></h2>
                    <p class="lead text-muted mb-4">
                        {% blocktrans %}You didn't buy anything big. Yet somehow ₹20,000 vanished.{% endblocktrans %}
                    </p>
                    <div class="story-pain-points mb-5">
                        <div class="d-flex align-items-center gap-3 mb-3 p-3 bg-body rounded-4 shadow-sm border-start border-4 border-danger border-opacity-50">
                            <div class="rounded-circle bg-danger bg-opacity-10 p-2" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-cup-hot text-danger"></i>
                            </div>
                            <span class="fw-medium">{% trans "Was it food?" %}</span>
                        </div>
                        <div class="d-flex align-items-center gap-3 mb-3 p-3 bg-body rounded-4 shadow-sm border-start border-4 border-primary border-opacity-50">
                            <div class="rounded-circle bg-primary bg-opacity-10 p-2" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-play-circle text-primary"></i>
                            </div>
                            <span class="fw-medium">{% trans "Subscriptions?" %}</span>
                        </div>
                        <div class="d-flex align-items-center gap-3 p-3 bg-body rounded-4 shadow-sm border-start border-4 border-success border-opacity-50">
                            <div class="rounded-circle bg-success bg-opacity-10 p-2" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-phone text-success"></i>
                            </div>
                            <span class="fw-medium">{% trans "Random UPI payments?" %}</span>
                        </div>
                    </div>
                    <p class="fs-5 text-muted mb-0">
                        {% blocktrans %}Most finance apps show charts. They don't tell the story. <strong>TrackMyRupee turns your transactions into a clear financial story.</strong>{% endblocktrans %}
                    </p>
                </div>
                <div class="col-lg-6 text-center" data-aos="zoom-in-up">
                    <div class="disappearing-money-viz px-4">
                        <!-- Custom CSS-based SVG Animation for "Disappearing Money" -->
                        <svg viewBox="0 0 400 300" class="w-100 h-auto" style="max-width: 450px;">
                            <defs>
                                <linearGradient id="moneyGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                    <stop offset="0%" style="stop-color:#00f260;stop-opacity:1" />
                                    <stop offset="100%" style="stop-color:#0575e6;stop-opacity:1" />
                                </linearGradient>
                            </defs>
                            <!-- Wallet -->
                            <path d="M100,200 L300,200 L310,240 L90,240 Z" fill="var(--surface-color)" stroke="var(--border-color)" stroke-width="2" />
                            <rect x="120" y="160" width="160" height="40" rx="4" fill="var(--surface-color)" stroke="var(--border-color)" stroke-width="2" />
                            
                            <!-- Floating Money Particles -->
                            <g class="money-particle" style="animation: floatUp 3s infinite ease-in-out;">
                                <rect x="150" y="140" width="30" height="15" rx="2" fill="url(#moneyGradient)" />
                                <text x="165" y="151" font-size="8" text-anchor="middle" fill="white" font-weight="bold">₹</text>
                            </g>
                            <g class="money-particle" style="animation: floatUp 4s infinite ease-in-out; animation-delay: 1s;">
                                <rect x="210" y="120" width="30" height="15" rx="2" fill="url(#moneyGradient)" />
                                <text x="225" y="131" font-size="8" text-anchor="middle" fill="white" font-weight="bold">₹</text>
                            </g>
                            <g class="money-particle" style="animation: floatUp 2.5s infinite ease-in-out; animation-delay: 0.5s;">
                                <rect x="180" y="90" width="30" height="15" rx="2" fill="url(#moneyGradient)" />
                                <text x="195" y="101" font-size="8" text-anchor="middle" fill="white" font-weight="bold">₹</text>
                            </g>
                        </svg>
                        <style>
                            @keyframes floatUp {
                                0% { transform: translateY(50px); opacity: 0; }
                                20% { opacity: 1; }
                                100% { transform: translateY(-150px); opacity: 0; }
                            }
                        </style>
                        <div class="mt-4 p-4 bg-body rounded-4 shadow border text-center">
                            <span class="h1 fw-bold text-danger mb-0">₹0.00</span>
                            <div class="text-muted small text-uppercase">{% trans "Remaining Balance" %}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Dashboard Story Section (Magic Reveal) -->
    <section class="py-5 blue-tint-bg overflow-hidden">
        <div class="container py-5">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 order-lg-2" data-aos="fade-left">
                    <div class="story-card p-4 p-md-5 bg-body rounded-4 shadow-lg border border-primary border-opacity-25 position-relative">
                        <div class="position-absolute top-0 end-0 m-4">
                            <span class="badge bg-primary rounded-pill">{% trans "Real Example" %}</span>
                        </div>
                        <h3 class="fw-bold mb-4">{% trans "Your Financial Story" %}</h3>
                        
                        <div class="story-metrics mb-5">
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="p-3 bg-body-tertiary rounded-3">
                                        <div class="small text-muted mb-1">{% trans "Income" %}</div>
                                        <div class="h4 fw-bold mb-0">₹2,01,000</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-body-tertiary rounded-3">
                                        <div class="small text-muted mb-1">{% trans "Lifestyle" %}</div>
                                        <div class="h4 fw-bold mb-0 text-danger">₹43,470</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-body-tertiary rounded-3">
                                        <div class="small text-muted mb-1">{% trans "Investments" %}</div>
                                        <div class="h4 fw-bold mb-0 text-success">₹45,000</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-primary bg-opacity-75 text-white rounded-3 shadow">
                                        <div class="small opacity-75 mb-1">{% trans "Savings Rate" %}</div>
                                        <div class="h4 fw-bold mb-0">78%</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="p-4 bg-success bg-opacity-10 rounded-4 border border-success border-opacity-25">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-lightning-charge-fill text-success fs-3"></i>
                                <div>
                                    <p class="mb-0 fw-bold text-success">
                                        {% trans "If you maintain this pace, you could save ₹9,00,000 this year." %}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 order-lg-1" data-aos="fade-right">
                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3 fw-bold">
                        <i class="bi bi-magic me-1"></i> {% trans "Your Financial Superpower" %}
                    </span>
                    <h2 class="display-4 fw-bold mb-4">{% trans "Your Financial Story," %}<br><span class="text-gradient">{% trans "Instantly." %}</span></h2>
                    <p class="lead text-muted mb-4">
                        {% blocktrans %}We don't just show you numbers. We tell you what those numbers mean for your future.{% endblocktrans %}
                    </p>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-check-circle-fill text-primary mt-1"></i>
                            <div>
                                <h6 class="fw-bold mb-1">{% trans "Lifestyle vs Investments" %}</h6>
                                <p class="small text-muted">{% trans "Instantly see if your spending matches your priorities." %}</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-start gap-3">
                            <i class="bi bi-check-circle-fill text-primary mt-1"></i>
                            <div>
                                <h6 class="fw-bold mb-1">{% trans "Wealth Insights" %}</h6>
                                <p class="small text-muted">{% trans "Proactive analysis of your saving habits and growth opportunities." %}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Outcome-Based Sections -->
    <section id="outcomes" class="py-5">
        <div class="container py-5">
            <div class="row g-4 text-center">
                <!-- Outcome 1: See Where Your Salary Actually Goes -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="h-100 p-4 rounded-4 border bg-body-tertiary shadow-sm d-flex flex-column align-items-center">
                        <div class="outcome-icon-box mb-4 bg-primary bg-opacity-10 text-primary mx-auto">
                            <i class="bi bi-pie-chart-fill fs-3"></i>
                        </div>
                        <h3 class="h4 fw-bold mb-3">{% trans "See where your salary" %} <span class="text-gradient">{% trans "actually goes" %}</span></h3>
                        <p class="text-muted mb-4 small">{% trans "Instantly visualize lifestyle spending, investments, and savings." %}</p>
                        <div class="mt-auto w-100 p-3 bg-body rounded-3 border border-opacity-10">
                            <div class="mb-2">
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-danger" role="progressbar" style="width: 21%;"></div>
                                </div>
                            </div>
                            <div class="mb-2">
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: 45%;"></div>
                                </div>
                            </div>
                            <div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-primary" role="progressbar" style="width: 34%;"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Outcome 2: Catch Expensive Habits Early -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="h-100 p-4 rounded-4 border bg-body-tertiary shadow-sm d-flex flex-column align-items-center">
                        <div class="outcome-icon-box mb-4 bg-warning bg-opacity-10 text-warning mx-auto">
                            <i class="bi bi-lightning-charge-fill fs-3"></i>
                        </div>
                        <h3 class="h4 fw-bold mb-3">{% trans "Catch expensive" %} <span class="text-gradient">{% trans "habits early" %}</span></h3>
                        <p class="text-muted mb-4 small">{% trans "Spot categories where spending is quietly growing." %}</p>
                        <div class="mt-auto w-100 p-3 bg-body rounded-3 border border-opacity-10 text-start position-relative overflow-hidden">
                            <div class="badge bg-danger position-absolute top-0 end-0 m-2 pulse-small" style="font-size: 0.6rem;">{% trans "Alert" %}</div>
                            <h6 class="fw-bold mb-1 small">{% trans "Food & Dining" %}</h6>
                            <div class="d-flex align-items-baseline gap-1">
                                <span class="fw-bold text-danger small">+42%</span>
                                <span class="text-muted" style="font-size: 0.7rem;">{% trans "vs last month" %}</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Outcome 3: Predict Your Financial Future -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="h-100 p-4 rounded-4 border bg-body-tertiary shadow-sm d-flex flex-column align-items-center">
                        <div class="outcome-icon-box mb-4 bg-success bg-opacity-10 text-success mx-auto">
                            <i class="bi bi-graph-up-arrow fs-3"></i>
                        </div>
                        <h3 class="h4 fw-bold mb-3">{% trans "Predict your" %} <span class="text-gradient">{% trans "financial future" %}</span></h3>
                        <p class="text-muted mb-4 small">{% trans "See how much you could save if your current habits continue." %}</p>
                        <div class="mt-auto w-100 p-3 bg-body rounded-3 border border-opacity-10">
                             <div class="d-flex align-items-center justify-content-center gap-2">
                                <div class="text-center">
                                    <div class="fw-bold small">₹1.2L</div>
                                </div>
                                <i class="bi bi-arrow-right small text-muted"></i>
                                <div class="text-center">
                                    <div class="fw-bold text-success small">₹4.8L</div>
                                </div>
                             </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Before vs After Section -->
    <section class="py-5 white-section-bg">
        <div class="container py-5">
            <div class="text-center mb-5" data-aos="fade-up">
                <h2 class="display-4 fw-bold">{% trans "The" %} <span class="text-gradient">{% trans "Transformation" %}</span></h2>
                <p class="lead text-muted">{% trans "How TrackMyRupee changes your financial life." %}</p>
            </div>
            <div class="row g-4 justify-content-center">
                <div class="col-lg-5" data-aos="fade-right">
                    <div class="comparison-card before-card p-4 p-md-5">
                        <h3 class="fw-bold mb-4 text-danger">{% trans "Before TrackMyRupee" %}</h3>
                        <ul class="comparison-list">
                            <li class="text-muted">
                                <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                                <span>{% trans "Salary disappears every month" %}</span>
                            </li>
                            <li class="text-muted">
                                <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                                <span>{% trans "Excel sheets everywhere" %}</span>
                            </li>
                            <li class="text-muted">
                                <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                                <span>{% trans "No idea where money goes" %}</span>
                            </li>
                            <li class="text-muted">
                                <i class="bi bi-x-circle-fill text-danger fs-5"></i>
                                <span>{% trans "No clear savings insight" %}</span>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-1 d-flex align-items-center justify-content-center py-3">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                        <i class="bi bi-arrow-right-short fs-1 text-primary d-none d-lg-block"></i>
                        <i class="bi bi-arrow-down-short fs-1 text-primary d-lg-none"></i>
                    </div>
                </div>
                <div class="col-lg-5" data-aos="fade-left">
                    <div class="comparison-card after-card p-4 p-md-5">
                        <h3 class="fw-bold mb-4 text-primary">{% trans "After TrackMyRupee" %}</h3>
                        <ul class="comparison-list">
                            <li>
                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                <span class="fw-bold">{% trans "See where your salary actually goes" %}</span>
                            </li>
                            <li>
                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                <span class="fw-bold">{% trans "Catch expensive habits early" %}</span>
                            </li>
                            <li>
                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                <span class="fw-bold">{% trans "Track investments & wealth growth" %}</span>
                            </li>
                            <li>
                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                <span class="fw-bold">{% trans "Understand your financial future" %}</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="process-section overflow-hidden">
        <div class="container py-4">
            <div class="text-center mb-5" data-aos="fade-down">
                <h2 class="display-4 fw-bold">Simple. Powerful. <span class="text-gradient">Fast.</span></h2>
            </div>
            <div class="row g-4">
                <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="step-card position-relative">
                        <span class="step-number">01</span>
                        <i class="bi bi-plus-square fs-1 text-primary mb-4 d-block"></i>
                        <h3 class="fw-bold mb-3">Track</h3>
                        <p class="text-muted">Log your income and expenses in seconds with our optimized entry forms.
                            Manual or bulk upload — your choice.</p>
                    </div>
                </div>
                <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="step-card position-relative">
                        <span class="step-number">02</span>
                        <i class="bi bi-search fs-1 text-success mb-4 d-block"></i>
                        <h3 class="fw-bold mb-3">Analyze</h3>
                        <p class="text-muted">Our engine automatically classifies and visualizes your data into stunning
                            charts and trends.</p>
                    </div>
                </div>
                <div class="col-lg-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="step-card position-relative">
                        <span class="step-number">03</span>
                        <i class="bi bi-shield-lock-fill fs-1 text-info mb-4 d-block"></i>
                        <h3 class="fw-bold mb-3">Master</h3>
                        <p class="text-muted">Set budgets, monitor limits, and watch your financial health improve month
                            after month.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <!-- Pricing Section -->
    <section id="pricing" class="py-5 position-relative">
        <div class="container py-5">
            <div class="row justify-content-center text-center mb-5" data-aos="fade-up">
                <div class="col-lg-8">
                    <span class="stats-badge mb-3 text-primary border-primary">
                        <i class="bi bi-stars"></i> Simple, Transparent Pricing
                    </span>
                    <h2 class="display-4 fw-bold mb-3">{% trans "Less than" %} <span class="text-gradient">{% trans "₹2/day" %}</span> {% trans "to understand your money." %}</h2>
                    <p class="lead text-muted mb-4">{% trans "Start for free, upgrade when you need more power. Your financial clarity is worth the coffee change." %}</p>
                    <div class="d-flex flex-column flex-md-row justify-content-center gap-4 text-muted small fw-medium">
                        <span><i class="bi bi-check2 text-success me-1"></i>{% trans "Simple pricing. No hidden charges." %}</span>
                        <span><i class="bi bi-check2 text-success me-1"></i>{% trans "Start free. Upgrade when you love it." %}</span>
                    </div>
                </div>
            </div>

            <!-- Monthly / Yearly Toggle -->
            <div class="row justify-content-center mb-4" data-aos="fade-up">
                <div class="col-auto">
                    <div class="d-flex align-items-center gap-3 bg-body-tertiary rounded-pill px-4 py-2">
                        <span id="lp-label-monthly" class="fw-semibold text-muted">Monthly</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch" id="lpBillingToggle" checked
                                aria-label="Toggle Billing Frequency"
                                style="width: 3em; height: 1.5em; cursor: pointer;">
                        </div>
                        <span id="lp-label-yearly" class="fw-semibold">Yearly
                            <span class="badge bg-success bg-opacity-75 ms-1 rounded-pill" style="font-size: 0.7em;">Save ~40%</span>
                        </span>
                    </div>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-3 g-4 mb-3 text-center">
                <!-- Free Plan -->
                <div class="col" data-aos="fade-up" data-aos-delay="100">
                    <div class="card mb-4 rounded-4 shadow-sm border-0 h-100 position-relative"
                        style="background: var(--surface-color);">
                        <div class="card-header py-3 bg-transparent border-0 mt-3">
                            <h4 class="my-0 fw-bold">Free</h4>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h3 class="card-title pricing-card-title display-5 fw-bold">₹0<small
                                    class="text-muted fw-light fs-4">/mo</small></h3>
                            <ul class="list-unstyled mt-3 mb-4 text-start mx-auto text-muted">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Unlimited
                                    Expenses</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Unlimited
                                    Income Entries</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>5 Budget
                                    Categories</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>1 Savings Goal</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Basic Reports
                                </li>
                                <li class="mb-2 text-muted"><i class="bi bi-dash-circle me-2"></i>Recurring Transactions
                                </li>
                                <li class="mb-2 text-muted"><i class="bi bi-dash-circle me-2"></i>Email Reminders</li>
                            </ul>
                            <a href="{% url 'account_signup' %}"
                                class="w-100 btn btn-lg btn-theme-adaptive mt-auto rounded-pill fw-bold">Sign up for
                                free</a>
                        </div>
                    </div>
                </div>

                <!-- Premium Plan -->
                <div class="col" data-aos="fade-up" data-aos-delay="200">
                    <div class="card mb-4 rounded-4 shadow border-primary h-100 position-relative"
                        style="background: var(--surface-color); border: 2px solid #0575e6;">
                        <div class="position-absolute top-0 start-50 translate-middle">
                            <span class="badge rounded-pill text-bg-primary px-3 py-2 shadow-sm">MOST POPULAR</span>
                        </div>
                        <div class="card-header py-3 bg-primary bg-opacity-10 border-0">
                            <h4 class="my-0 fw-bold text-primary">Plus <span class="badge bg-danger ms-2 rounded-pill"
                                    style="font-size: 0.6em;">LIMITED OFFER</span></h4>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h3 class="card-title pricing-card-title display-5 fw-bold">
                                <span class="lp-plan-price"
                                    data-monthly="{{ plans_monthly.PLUS.price|default:'0'|floatformat:0 }}"
                                    data-yearly="{{ plans_yearly.PLUS.price|default:'0'|floatformat:0 }}">
                                    ₹{% if plans_yearly.PLUS %}{{ plans_yearly.PLUS.price|floatformat:0 }}{% else %}0{% endif %}
                                </span>
                                <small class="text-muted fw-light fs-4 lp-plan-suffix">/yr</small>
                            </h3>
                            <ul class="list-unstyled mt-3 mb-4 text-start mx-auto text-muted">
                                <li class="mb-2"><i
                                        class="bi bi-check-circle-fill text-success me-2"></i><strong>Everything in
                                        Free</strong></li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>10 Budget
                                    Categories</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>3 Recurring
                                    Transactions</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>3 Savings Goals</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Email
                                    Reminders</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Export to
                                    CSV/Excel</li>
                                <li class="mb-2"><i class="bi bi-star-fill text-warning me-2"></i><strong>Year in Review</strong></li>
                            </ul>
                            <a href="{% url 'account_signup' %}"
                                class="w-100 btn btn-lg btn-primary mt-auto rounded-pill fw-bold shadow-lg"
                                style="background: var(--primary-gradient); border: none;">Get Plus</a>
                        </div>
                    </div>
                </div>

                <!-- Pro Plan -->
                <div class="col" data-aos="fade-up" data-aos-delay="300">
                    <div class="card mb-4 rounded-4 shadow-sm border-0 h-100 position-relative"
                        style="background: var(--surface-color);">
                        <div class="card-header py-3 bg-transparent border-0">
                            <h4 class="my-0 fw-normal">Pro <span class="badge bg-danger ms-2 rounded-pill"
                                    style="font-size: 0.6em;">LIMITED OFFER</span></h4>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h3 class="card-title pricing-card-title display-5 fw-bold">
                                <span class="lp-plan-price"
                                    data-monthly="{{ plans_monthly.PRO.price|default:'0'|floatformat:0 }}"
                                    data-yearly="{{ plans_yearly.PRO.price|default:'0'|floatformat:0 }}">
                                    ₹{% if plans_yearly.PRO %}{{ plans_yearly.PRO.price|floatformat:0 }}{% else %}0{% endif %}
                                </span>
